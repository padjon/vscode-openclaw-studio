    "prefix": "openclaw-plugin",
    "body": [
      "{",
      "\t\"$schema\": \"../../schemas/openclaw.plugin.schema.json\",",
      "\t\"id\": \"$1\",",
      "\t\"name\": \"$2\",",
      "\t\"description\": \"$3\",",
      "\t\"configSchema\": {",
      "\t\t\"type\": \"object\",",
      "\t\t\"additionalProperties\": false,",
      "\t\t\"properties\": {}",
      "\t}",
      "}"
    ],
    "description": "Create a starter openclaw.plugin.json manifest."
  }
}
