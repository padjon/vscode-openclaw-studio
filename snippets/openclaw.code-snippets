    "body": [
      "{",
      "\t\"$schema\": \"./schemas/openclaw.schema.json\",",
      "\t\"agent\": {",
      "\t\t\"model\": \"anthropic/claude-opus-4-6\"",
      "\t},",
      "\t\"gateway\": {",
      "\t\t\"port\": 18789,",
